# Environment Variables Configuration Example

# Database Connection (PostgreSQL / Cloudflare Hyperdrive)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookingengine"

# JWT Auth Secrets
JWT_SECRET="super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production-min-32-chars"

# Third-Party API Keys
STAYFLEXI_API_KEY=""
STAYFLEXI_HOTEL_ID=""
TTLOCK_CLIENT_ID=""
TTLOCK_CLIENT_SECRET=""

# Cloudflare Infrastructure Bindings
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
